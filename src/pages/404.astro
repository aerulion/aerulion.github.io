---
import Layout from '../layouts/Layout.astro';
import GradientBackground from "../components/GradientBackground.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
---

<Layout title="404 - Page Not Found" description="This page does not exist.">
    <GradientBackground/>
    <div class="not-found-section">
        <div class="not-found-card panel-cut">
            <p class="not-found-meta">AERULION / ROUTE ERROR</p>
            <img src="/assets/images/logo.svg" alt="aerulion logo" class="not-found-logo" width="160"
                 height="160">
            <h1>404</h1>
            <h2>Page Not Found</h2>
            <p>The page you're looking for doesn't exist or is no longer part of the current structure.</p>
            <Button href="/">Return to Home</Button>
        </div>
    </div>
    <Footer/>
</Layout>

<style>

    .not-found-card {
        width: min(100%, 720px);
        padding: clamp(2rem, 5vw, 4rem);
        display: grid;
        gap: var(--spacing-lg);
        justify-items: start;
    }

    .not-found-meta {
        font-family: var(--font-family-mono), monospace;
        font-size: var(--font-size-xs);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--spacing-sm);
    }

    .not-found-logo {
        width: 96px;
        height: auto;
        opacity: 0.92;
        margin-bottom: var(--spacing-sm);
    }

    h1 {
        font-family: var(--font-family-display), sans-serif;
        font-size: clamp(4rem, 12vw, 8rem);
        line-height: 0.9;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    h2 {
        color: var(--text-primary);
        font-size: clamp(1.5rem, 3vw, var(--font-size-4xl));
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    p {
        color: var(--text-secondary);
        font-size: var(--font-size-lg);
    }

    .not-found-section {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: clamp(1rem, 3vw, 2rem);
    }

</style>