---
interface Props {
    position: number;
    title: string;
    description: string;
    iconUrl: string;
    iconAlt: string;
}

const {position, title, description, iconUrl, iconAlt} = Astro.props;
---

<article class="project-card panel-cut">
    <div class="project-topline">
        <span class="project-index">0{position}</span>
        <span class="project-rule" aria-hidden="true"></span>
        <span class="project-kind">SYSTEM</span>
    </div>
    <div class="project-head">
        <div class="project-icon">
            <img src={iconUrl} alt={iconAlt} width="64" height="64" loading="lazy">
        </div>
        <h3 class="project-title">{title}</h3>
    </div>
    <div class="project-content">
        <p class="project-description">{description}</p>
    </div>
</article>

<style>
    .project-card {
        display: grid;
        gap: var(--spacing-xl);
        min-height: 100%;
        padding: clamp(1.5rem, 3vw, 2.5rem);
        animation: fadeInUp 0.6s ease-out backwards;
    }

    .project-card:nth-of-type(1) {
        animation-delay: 0.1s;
    }

    .project-card:nth-of-type(2) {
        animation-delay: 0.2s;
    }

    .project-card:hover {
        border-color: var(--line-strong);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.018));
    }

    .project-topline {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .project-index,
    .project-kind {
        font-family: var(--font-family-mono), monospace;
        font-size: var(--font-size-xs);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .project-rule {
        display: block;
        height: 1px;
        background: linear-gradient(90deg, var(--line-strong), transparent);
    }

    .project-head {
        display: flex;
        align-items: center;
        gap: var(--spacing-lg);
    }

    .project-icon {
        width: 72px;
        height: 72px;
        display: grid;
        place-items: center;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.025);
        flex-shrink: 0;
    }

    .project-icon img {
        width: 42px;
        height: 42px;
        object-fit: contain;
        filter: grayscale(1) brightness(1.25) contrast(1.05);
    }

    .project-title {
        font-family: var(--font-family-display), sans-serif;
        font-size: clamp(1.8rem, 3vw, var(--font-size-4xl));
        font-weight: 600;
        line-height: 0.96;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .project-description {
        font-size: clamp(1rem, 1.1vw, var(--font-size-lg));
        color: var(--text-secondary);
        line-height: 1.85;
    }

    @media (max-width: 768px) {
        .project-head {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>