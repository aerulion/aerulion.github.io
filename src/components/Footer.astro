---
import {getCurrentYear} from '../utils/dates';
import {commitUrl, repoUrl, shortCommitHash} from "../utils/git.ts";

const currentYear = getCurrentYear();
---

<footer>
    <div class="container">
        <div class="footer-content">
            <p>
                &copy; 2022-{currentYear}
                <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="footer-link">
                    aerulion.net
                </a>
                {' @ '}
                <a href={commitUrl} target="_blank" rel="noopener noreferrer" class="footer-link commit-hash">
                    {shortCommitHash}
                </a>
            </p>
        </div>
    </div>
</footer>

<style>
    footer {
        padding: var(--spacing-2xl) 0;
        border-top: 1px solid var(--line);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
    }

    .footer-content {
        display: flex;
        justify-content: center;
    }

    .footer-content p {
        color: var(--text-muted);
        font-family: var(--font-family-mono), monospace;
        font-size: var(--font-size-xs);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        justify-content: center;
    }

    .footer-link {
        color: inherit;
        text-decoration: none;
        transition: color var(--transition-base), opacity var(--transition-base);
    }

    .footer-link:hover {
        opacity: 1;
        color: var(--text-primary);
    }

    .commit-hash {
        font-family: var(--font-family-mono), monospace;
        font-size: 1em;
    }
</style>