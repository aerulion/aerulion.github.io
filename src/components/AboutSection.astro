---
import {age} from '../utils/dates';
---

<section class="about-section">
    <div class="container">
        <div class="about-wrapper panel-cut">
            <div class="section-header">
                <p class="section-eyebrow">CONTEXT / 01</p>
                <h2 class="section-title">Built for scale, precision and long-term systems.</h2>
                <p class="section-subtitle">
                    Custom Java architecture, gameplay systems and performant server-side tooling for projects that
                    need stability under real load.
                </p>
                <div class="section-line" aria-hidden="true"></div>
            </div>
            <div class="about-content">
                <dl class="about-facts">
                    <div class="fact-row">
                        <dt>Role</dt>
                        <dd>Lead Developer</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Base</dt>
                        <dd>Germany / {age}</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Focus</dt>
                        <dd>Paper, Bukkit, Java, database architecture</dd>
                    </div>
                    <div class="fact-row">
                        <dt>Primary Client</dt>
                        <dd>Corpium</dd>
                    </div>
                </dl>

                <div class="about-text">
                    <p>
                        My name is aerulion, I'm a {age}-year-old <strong>Java developer from Germany</strong> with a
                        focus on building <strong>custom gameplay systems</strong> that push beyond default Minecraft
                        constraints while staying coherent and maintainable.
                    </p>
                    <p>
                        As the <strong>lead developer</strong> at <a
                            href="https://corpium.net/"
                            class="modern-link"
                            rel="noopener"
                            target="_blank"
                    >Corpium</a>, one of the oldest German Minecraft servers, I design and maintain sophisticated
                        <strong>plugin ecosystems</strong> with performance-focused features, complex mechanics and a
                        controlled vanilla-adjacent feel.
                    </p>
                    <p>
                        My expertise ranges from low-level Java optimization to high-level system design, with
                        particular strengths in <strong>database architecture</strong> and <strong>scalable plugin
                        development</strong>. Clean abstractions, longevity and operational clarity are core to the
                        way I build.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-section {
        padding: 0 0 var(--spacing-5xl);
        animation: fadeInUp 0.8s ease-out;
    }

    .about-wrapper {
        padding: clamp(2rem, 4vw, 4rem);
    }

    .about-content {
        display: grid;
        grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr);
        gap: clamp(2rem, 5vw, 5rem);
        align-items: start;
    }

    .about-facts {
        display: grid;
        gap: 0.85rem;
        padding-top: 0.2rem;
    }

    .fact-row {
        display: grid;
        gap: 0.3rem;
        padding: 0.95rem 0;
        border-top: 1px solid var(--line);
    }

    .fact-row:last-child {
        border-bottom: 1px solid var(--line);
    }

    .fact-row dt {
        font-family: var(--font-family-mono), monospace;
        font-size: var(--font-size-xs);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--text-muted);
    }

    .fact-row dd {
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: var(--font-size-sm);
    }

    .about-text p {
        font-size: clamp(1rem, 1.4vw, var(--font-size-xl));
        line-height: 1.9;
        color: var(--text-secondary);
        margin-bottom: var(--spacing-xl);
    }

    .about-text strong {
        color: var(--text-primary);
        font-weight: 600;
    }

    .about-text p:last-child {
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .about-content {
            grid-template-columns: 1fr;
            gap: var(--spacing-2xl);
        }
    }

    @media (max-width: 480px) {
        .about-wrapper {
            padding: var(--spacing-xl);
        }
    }
</style>