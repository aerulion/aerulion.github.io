---
import ProjectCard from './ProjectCard.astro';
import {projects} from '../data/projects';
---

<section class="projects-section">
    <div class="container">
        <div class="section-header">
            <p class="section-eyebrow">SELECTED SYSTEMS / 02</p>
            <h2 class="section-title">Two large-scale builds shaped around progression, storage and control.</h2>
            <p class="section-subtitle">Core systems built for live gameplay, long sessions and server-side
                reliability.</p>
            <div class="section-line" aria-hidden="true"></div>
        </div>
        <div class="projects-grid">
            {projects.map((project, index) => (
                    <ProjectCard
                            position={index + 1}
                            title={project.title}
                            description={project.description}
                            iconUrl={project.iconUrl}
                            iconAlt={project.iconAlt}
                    />
            ))}
        </div>
    </div>
</section>

<style>
    .projects-section {
        padding: 0 0 var(--spacing-5xl);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: var(--spacing-xl);
    }

    @media (max-width: 1200px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 480px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>